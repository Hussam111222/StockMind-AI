# Required: your Anthropic API key (console.anthropic.com) — used for news search + AI analysis
ANTHROPIC_API_KEY=

# Optional: a real market-data provider key. Without it, the app falls back to
# clearly-labeled simulated price data so the dashboard still works end to end.
# Alpha Vantage free tier: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# Optional: dedicated financial news API (structured, more reliable than open web search).
# Free tier signup: https://finnhub.io/register
# Without it, the app falls back to live web search via the Anthropic API (still works fine).
FINNHUB_API_KEY=

# Port the server listens on
PORT=3000

# Cron schedule for the daily full refresh job (price + technicals + ML + news + narrative)
REFRESH_CRON=0 6 * * *

# Cron schedule for the lighter, more frequent news-only refresh (re-checks news + rescoring
# without re-fetching prices or retraining the ML model — keeps things up to date intraday)
NEWS_CRON=0 */3 * * *

# Simple shared-secret token required to call POST /api/refresh manually
ADMIN_TOKEN=change-me
